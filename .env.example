# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/connectplus?schema=public"

# Encryption key for secrets at rest (32 bytes hex = 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# Rainbow CPaaS — S2S callback URL (where Rainbow sends webhooks)
# Credentials (login, password, appId, appSecret) are provided by each
# agent through the /agent page UI — never stored on disk.
RAINBOW_HOST_CALLBACK=""
# DEFAULT_TENANT_ID — tenant ID for single-tenant deployments
# DEFAULT_TENANT_ID=""

# App
NODE_ENV="development"
PORT=3001
