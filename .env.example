# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/connectplus?schema=public"

# Encryption key for secrets at rest (32 bytes hex = 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# Rainbow CPaaS
RAINBOW_HOST="sandbox"

# App
NODE_ENV="development"
PORT=3001
