{
  "slug": "salesforce-crm",
  "category": "crm",
  "displayName": "Salesforce CRM",
  "description": "Contact search, activity logging, and deal sync with Salesforce CRM",
  "vendor": "Salesforce",
  "vendorUrl": "https://www.salesforce.com/",
  "docsUrl": "https://developer.salesforce.com/docs/atlas.en-us.api_rest.meta/api_rest/intro_rest.htm",
  "auth": {
    "type": "oauth2",
    "scopes": ["api", "refresh_token"],
    "dcAware": false,
    "authUrl": "https://login.salesforce.com/services/oauth2/authorize",
    "tokenUrl": "https://login.salesforce.com/services/oauth2/token"
  },
  "capabilities": [
    "contact_search",
    "contact_sync",
    "activity_logging",
    "deal_sync",
    "write_back",
    "webhook_inbound",
    "health_check"
  ],
  "settings": [
    {
      "key": "instanceUrl",
      "type": "url",
      "label": "Salesforce Instance URL",
      "description": "Your Salesforce instance URL (e.g. https://mycompany.my.salesforce.com)",
      "required": true,
      "placeholder": "https://mycompany.my.salesforce.com"
    },
    {
      "key": "apiVersion",
      "type": "string",
      "label": "API Version",
      "description": "Salesforce REST API version",
      "required": false,
      "default": "v59.0"
    }
  ],
  "endpoints": {
    "activate": true,
    "deactivate": true,
    "diagnostics": true,
    "auditLogs": true,
    "webhooks": true,
    "test": true
  },
  "prerequisites": [
    "Salesforce Enterprise Edition or higher",
    "Connected App configured with OAuth2",
    "API access enabled for user"
  ],
  "notes": "Uses Salesforce REST API. Supports both Production and Sandbox orgs."
}
